---
import { ui, defaultLang } from "../i18n/ui";

const { lang = defaultLang } = Astro.props;
const t = ui[lang as keyof typeof ui] || ui[defaultLang];
const rsvpEndpoint = import.meta.env.PUBLIC_RSVP_ENDPOINT || "";
---

<div class="rsvp-form-wrapper">
  <p class="rsvp-deadline">
    {t["rsvp.deadlinemsg"]}
    <strong>{t["rsvp.deadline"]}</strong>.
  </p>

  {
    !rsvpEndpoint && (
      <p class="rsvp-error">
        Missing <code>PUBLIC_RSVP_ENDPOINT</code>. Set it in <code>.env</code>{" "}
        or GitHub Actions secrets.
      </p>
    )
  }

  <iframe name="rsvp_hidden_iframe" class="hidden"></iframe>

  <form
    id="rsvpForm"
    class="rsvp-form"
    action={rsvpEndpoint}
    method="POST"
    target="rsvp_hidden_iframe"
    data-lang={lang}
  >
    <!-- Always visible: Name, Email, Attending -->
    <div class="form-row">
      <label class="form-field">
        <span class="form-label">{t["rsvp.fullname"]}</span>
        <input name="fullName" required class="form-input" />
      </label>

      <label class="form-field">
        <span class="form-label">{t["rsvp.email"]}</span>
        <input name="email" type="email" class="form-input" />
      </label>
    </div>

    <div class="form-row">
      <label class="form-field">
        <span class="form-label">{t["rsvp.attending"]}</span>
        <select
          name="attending"
          id="attendingSelect"
          required
          class="form-input"
        >
          <option value="" disabled selected>—</option>
          <option value="yes">{t["rsvp.yes"]}</option>
          <option value="no">{t["rsvp.no"]}</option>
        </select>
      </label>
    </div>

    <!-- Conditional: Only shown when attending = YES -->
    <div id="attendingYesFields" class="conditional-fields hidden">
      <div class="form-row">
        <label class="form-field">
          <span class="form-label">{t["rsvp.bus_gandia_alzira"]}</span>
          <select name="busGandiaAlzira" class="form-input">
            <option value="" disabled selected>—</option>
            <option value="yes">{t["rsvp.yes"]}</option>
            <option value="no">{t["rsvp.no"]}</option>
          </select>
        </label>

        <label class="form-field">
          <span class="form-label">{t["rsvp.bus_alzira_gandia"]}</span>
          <select name="busAlziraGandia" id="busAlziraGandiaSelect" class="form-input">
            <option value="" disabled selected>—</option>
            <option value="yes">{t["rsvp.yes"]}</option>
            <option value="no">{t["rsvp.no"]}</option>
          </select>
        </label>
      </div>

      <!-- Conditional: Only shown when return bus = YES -->
      <div id="busAlziraGandiaTimeField" class="hidden">
        <label class="form-field">
          <span class="form-label">{t["rsvp.bus_alzira_gandia_time"]}</span>
          <select name="busAlziraGandiaTime" id="busAlziraGandiaTimeSelect" class="form-input">
            <option value="" disabled selected>—</option>
            <option value="22:00">{t["rsvp.bus_time_22"]}</option>
            <option value="01:00">{t["rsvp.bus_time_01"]}</option>
          </select>
        </label>
      </div>

      <label class="form-field">
        <span class="form-label">{t["rsvp.dietary"]}</span>
        <input name="dietary" class="form-input" />
      </label>

      <label class="form-field">
        <span class="form-label">{t["rsvp.shoe_size"]}</span>
        <input
          name="shoeSize"
          type="number"
          min="35"
          max="45"
          class="form-input"
          placeholder="36, 37, 38..."
        />
      </label>

      <label class="form-field">
        <span class="form-label">{t["rsvp.message"]}</span>
        <textarea
          name="message"
          rows="4"
          class="form-input form-textarea"
          disabled></textarea>
      </label>
    </div>

    <div id="attendingNoFields" class="conditional-fields hidden">
      <label class="form-field">
        <span class="form-label">{t["rsvp.message_not_attending"]}</span>
        <textarea
          name="message"
          rows="4"
          class="form-input form-textarea"
          disabled></textarea>
      </label>
    </div>

    <!-- Honeypot (spam trap): bots fill it, humans won't -->
    <input name="website" tabindex="-1" autocomplete="off" class="hidden" />

    <button
      id="rsvpBtn"
      type="submit"
      class="btn btn-primary submit-btn"
      disabled={!rsvpEndpoint}
    >
      {t["rsvp.send"]}
    </button>

    <p id="rsvpStatus" class="rsvp-status"></p>
  </form>

  <div
    id="i18n-data"
    class="hidden"
    data-sending={t["rsvp.sending"]}
    data-sent={t["rsvp.sent"]}
    data-success={t["rsvp.success"]}
    data-validation-required={t["rsvp.validation.required"]}
    data-validation-name={t["rsvp.validation.name_required"]}
  >
  </div>

  <script>
    const form = document.getElementById("rsvpForm") as HTMLFormElement | null;
    const btn = document.getElementById("rsvpBtn") as HTMLButtonElement | null;
    const status = document.getElementById("rsvpStatus");
    const i18n = document.getElementById("i18n-data");
    const attendingSelect = document.getElementById(
      "attendingSelect",
    ) as HTMLSelectElement | null;
    const attendingYesFields = document.getElementById("attendingYesFields");
    const attendingNoFields = document.getElementById("attendingNoFields");

    // Return bus time elements
    const busAlziraGandiaSelect = document.getElementById(
      "busAlziraGandiaSelect",
    ) as HTMLSelectElement | null;
    const busAlziraGandiaTimeField = document.getElementById(
      "busAlziraGandiaTimeField",
    );
    const busAlziraGandiaTimeSelect = document.getElementById(
      "busAlziraGandiaTimeSelect",
    ) as HTMLSelectElement | null;

    // Get validation messages
    const validationRequired =
      i18n?.dataset.validationRequired || "Please select an option";
    const validationName =
      i18n?.dataset.validationName || "Please enter your name";

    // Set custom validation messages on required fields
    const fullNameInput = form?.querySelector(
      'input[name="fullName"]',
    ) as HTMLInputElement | null;
    const busGandiaSelect = form?.querySelector(
      'select[name="busGandiaAlzira"]',
    ) as HTMLSelectElement | null;
    const busAlziraSelect = form?.querySelector(
      'select[name="busAlziraGandia"]',
    ) as HTMLSelectElement | null;

    // Apply custom validation message for name
    if (fullNameInput) {
      fullNameInput.addEventListener("invalid", () => {
        fullNameInput.setCustomValidity(validationName);
      });
      fullNameInput.addEventListener("input", () => {
        fullNameInput.setCustomValidity("");
      });
    }

    // Apply custom validation messages for select fields
    [attendingSelect, busGandiaSelect, busAlziraSelect, busAlziraGandiaTimeSelect].forEach((select) => {
      if (select) {
        select.addEventListener("invalid", () => {
          select.setCustomValidity(validationRequired);
        });
        select.addEventListener("change", () => {
          select.setCustomValidity("");
        });
      }
    });

    // Toggle return bus time dropdown based on return bus selection
    function updateReturnBusTimeField() {
      if (!busAlziraGandiaSelect || !busAlziraGandiaTimeField || !busAlziraGandiaTimeSelect) return;

      if (busAlziraGandiaSelect.value === "yes") {
        busAlziraGandiaTimeField.classList.remove("hidden");
        busAlziraGandiaTimeSelect.required = true;
      } else {
        busAlziraGandiaTimeField.classList.add("hidden");
        busAlziraGandiaTimeSelect.required = false;
        busAlziraGandiaTimeSelect.value = "";
        // Reset to the disabled placeholder
        const placeholder = busAlziraGandiaTimeSelect.querySelector('option[disabled]') as HTMLOptionElement | null;
        if (placeholder) placeholder.selected = true;
      }
    }

    if (busAlziraGandiaSelect) {
      busAlziraGandiaSelect.addEventListener("change", updateReturnBusTimeField);
      updateReturnBusTimeField(); // Set initial state
    }

    // Toggle conditional fields based on attending selection
    function updateConditionalFields() {
      if (!attendingSelect || !attendingYesFields || !attendingNoFields) return;

      const value = attendingSelect.value;

      // Get both message textareas
      const messageYes = attendingYesFields.querySelector(
        'textarea[name="message"]',
      ) as HTMLTextAreaElement | null;
      const messageNo = attendingNoFields.querySelector(
        'textarea[name="message"]',
      ) as HTMLTextAreaElement | null;

      if (value === "yes") {
        attendingYesFields.classList.remove("hidden");
        attendingNoFields.classList.add("hidden");
        // Enable required on bus fields
        if (busGandiaSelect) busGandiaSelect.required = true;
        if (busAlziraSelect) busAlziraSelect.required = true;
        // Enable "yes" message, disable "no" message
        if (messageYes) messageYes.disabled = false;
        if (messageNo) messageNo.disabled = true;
      } else if (value === "no") {
        attendingYesFields.classList.add("hidden");
        attendingNoFields.classList.remove("hidden");
        // Disable required on bus fields and set default values
        if (busGandiaSelect) {
          busGandiaSelect.required = false;
          busGandiaSelect.value = "no";
        }
        if (busAlziraSelect) {
          busAlziraSelect.required = false;
          busAlziraSelect.value = "no";
        }
        // Also hide return bus time field
        if (busAlziraGandiaTimeField) busAlziraGandiaTimeField.classList.add("hidden");
        if (busAlziraGandiaTimeSelect) {
          busAlziraGandiaTimeSelect.required = false;
          busAlziraGandiaTimeSelect.value = "";
          const placeholder = busAlziraGandiaTimeSelect.querySelector('option[disabled]') as HTMLOptionElement | null;
          if (placeholder) placeholder.selected = true;
        }
        // Clear and disable hidden fields
        const dietaryInput = form?.querySelector(
          'input[name="dietary"]',
        ) as HTMLInputElement | null;
        const shoeSizeInput = form?.querySelector(
          'input[name="shoeSize"]',
        ) as HTMLInputElement | null;
        if (dietaryInput) dietaryInput.value = "";
        if (shoeSizeInput) shoeSizeInput.value = "";
        // Enable "no" message, disable "yes" message
        if (messageYes) {
          messageYes.disabled = true;
          messageYes.value = "";
        }
        if (messageNo) messageNo.disabled = false;
      } else {
        // No selection yet - hide both, disable required on bus fields
        attendingYesFields.classList.add("hidden");
        attendingNoFields.classList.add("hidden");
        if (busGandiaSelect) busGandiaSelect.required = false;
        if (busAlziraSelect) busAlziraSelect.required = false;
        if (busAlziraGandiaTimeSelect) busAlziraGandiaTimeSelect.required = false;
        if (busAlziraGandiaTimeField) busAlziraGandiaTimeField.classList.add("hidden");
        // Disable both message textareas
        if (messageYes) messageYes.disabled = true;
        if (messageNo) messageNo.disabled = true;
      }
    }

    // Initialize and listen for changes
    if (attendingSelect) {
      attendingSelect.addEventListener("change", updateConditionalFields);
      updateConditionalFields(); // Set initial state
    }

    // Form submission handler
    if (form && btn && status && i18n) {
      const tSending = i18n.dataset.sending || "Sending...";
      const tSent = i18n.dataset.sent || "Sent";
      const tSuccess = i18n.dataset.success || "Success!";

      form.addEventListener("submit", () => {
        btn.disabled = true;
        btn.textContent = tSending;

        window.setTimeout(() => {
          status.textContent = tSuccess;
          btn.textContent = tSent;
          form.reset();
          updateConditionalFields(); // Reset to default state
          updateReturnBusTimeField(); // Reset return bus time
        }, 600);
      });
    }
  </script>
</div>

<style>
  .rsvp-form-wrapper {
    max-width: 600px;
    margin: 0 auto;
  }

  .rsvp-deadline {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .rsvp-error {
    text-align: center;
    color: #b91c1c;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .rsvp-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .form-input {
    width: 100%;
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--text-primary);
    background: #fff;
    border: 1px solid var(--border-color);
    transition: border-color 0.2s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--text-primary);
  }

  /* Fix for mobile select dropdowns */
  select.form-input {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23666' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1rem;
    padding-right: 3rem;
    cursor: pointer;
  }

  /* Ensure proper touch target on mobile */
  @media (max-width: 640px) {
    select.form-input {
      min-height: 48px;
      font-size: 16px; /* Prevents iOS zoom on focus */
    }
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .conditional-fields {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .submit-btn {
    align-self: center;
    min-width: 200px;
    margin-top: 1rem;
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .rsvp-status {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
    min-height: 1.25rem;
  }

  .hidden {
    display: none !important;
  }
</style>
